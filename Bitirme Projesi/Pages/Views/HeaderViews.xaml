<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bitirme_Projesi.Pages.Views.HeaderViews">
    <Border BackgroundColor="#2D6A4F" 
        HeightRequest="80" 
        Padding="15,0" 
        StrokeThickness="0"
        VerticalOptions="Start">

        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,3" Radius="5" Opacity="0.15" />
        </Border.Shadow>

        <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">

            <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">

                <Border StrokeThickness="2"
                    Stroke="#74C69D"
                    HeightRequest="50"
                    WidthRequest="50"
                    StrokeShape="RoundRectangle 25">
                    <Image x:Name="ImgHeaderProfile"
                           Source="user_avatar.png" 
                           Aspect="AspectFill" />
                </Border>

                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Hoş Geldin," 
                       TextColor="#D8F3DC" 
                       FontSize="12" />
                    <Label x:Name="LblHeaderName"
                           Text="Kullanıcı Adı" 
                           TextColor="White" 
                           FontSize="18" 
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <ImageButton Grid.Column="2"
                     Source="settings_v2.png"
                     HeightRequest="28"
                     WidthRequest="28"
                     VerticalOptions="Center"
                     HorizontalOptions="End"
                     Clicked="OnSettingsClicked" />
        </Grid>
    </Border>
</ContentView>
