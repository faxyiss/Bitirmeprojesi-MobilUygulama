<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bitirme_Projesi.Pages.Views.NavigationBar">
    
    <Border BackgroundColor="White" 
            HeightRequest="70" 
            StrokeThickness="0"
            VerticalOptions="End">

        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-3" Radius="5" Opacity="0.1" />
        </Border.Shadow>

        <Grid ColumnDefinitions="*, *, *">

            <Grid x:Name="LayoutAkis" Grid.Column="0" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAkisTapped" />
                </Grid.GestureRecognizers>

                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2" Margin="0,0,0,20">
                    <Image x:Name="ImgAkis" Source="home_icon.png" HeightRequest="24" WidthRequest="24" />
                    <Label x:Name="LblAkis" Text="Akış" FontSize="12" TextColor="#707070" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <Grid x:Name="LayoutGorevler" Grid.Column="1" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGorevlerTapped" />
                </Grid.GestureRecognizers>

                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2" Margin="0,0,0,20">
                    <Image x:Name="ImgGorevler" Source="task_icon.png" HeightRequest="24" WidthRequest="24" />
                    <Label x:Name="LblGorevler" Text="Görevler" FontSize="12" TextColor="#707070" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <Grid x:Name="LayoutProfil" Grid.Column="2" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfilTapped" />
                </Grid.GestureRecognizers>

                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="2" Margin="0,0,0,20">
                    <Image x:Name="ImgProfil" Source="profile_icon.png" HeightRequest="24" WidthRequest="24" />
                    <Label x:Name="LblProfil" Text="Profil" FontSize="12" TextColor="#707070" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

        </Grid>
    </Border>
</ContentView>
