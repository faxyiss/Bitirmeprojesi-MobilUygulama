<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bitirme_Projesi.Pages.StartQuestPage"
             xmlns:controls="clr-namespace:Bitirme_Projesi.Pages.Views"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#F8F9F2"
             Title="">

    <Grid RowDefinitions="Auto, *">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="25">

                <Border StrokeShape="RoundRectangle 20" 
                        HeightRequest="280" 
                        BackgroundColor="White" 
                        StrokeThickness="2" 
                        StrokeDashArray="4,2" 
                        Stroke="#2D6A4F">
                    <Image x:Name="ImgSelected" 
                           Source="camera_placeholder.png" 
                           Aspect="AspectFill" />
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <Button Text="Kamera" BackgroundColor="#2D6A4F" TextColor="White" CornerRadius="12" Clicked="OnCameraClicked" />
                    <Button Grid.Column="1" Text="Galeri" BackgroundColor="White" TextColor="#2D6A4F" BorderColor="#2D6A4F" BorderWidth="1" CornerRadius="12" Clicked="OnGalleryClicked" />
                </Grid>

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="#E8F5E9" Padding="15" StrokeThickness="0">
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="10">
                            <Image Source="location_pin.png" HeightRequest="22" />
                            <Label x:Name="LblLocation" Text="Konum bekleniyor..." TextColor="#1B4332" VerticalOptions="Center" FontAttributes="Bold" />
                        </HorizontalStackLayout>
                        <Button x:Name="BtnGetLocation" Text="KONUMU DOĞRULA" BackgroundColor="#40916C" TextColor="White" CornerRadius="10" Clicked="OnGetLocationClicked" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Görev İsmi Belirle" FontAttributes="Bold" TextColor="#1B4332" Margin="5,0" />
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E0E0E0" BackgroundColor="White" Padding="15,5">
                        <Entry x:Name="EntTitle" Placeholder="Örn: Sahil Temizliği Etkinliği" PlaceholderColor="#A0A0A0" TextColor="Black" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Margin="0,10,0,40">
                    <Button Text="GÖREVE BAŞLA" 
                            BackgroundColor="#1B4332" 
                            TextColor="White" 
                            FontAttributes="Bold" 
                            HeightRequest="60" 
                            CornerRadius="15" 
                            Clicked="OnStartQuestClicked" />

                    <Button Text="İptal Et" 
                            BackgroundColor="Transparent" 
                            TextColor="#BC4749" 
                            Clicked="OnCancelClicked" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>