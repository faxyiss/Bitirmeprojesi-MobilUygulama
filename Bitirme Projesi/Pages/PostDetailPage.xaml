<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bitirme_Projesi.Pages.PostDetailPage"
             BackgroundColor="#F8F9F2"
             Title="Gönderi Detayı">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ÜST BİLGİ (Kullanıcı, Tarih ve Konum) -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="White" Padding="20,15" Spacing="5">
            <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" TextColor="#1B4332" />
            <HorizontalStackLayout Spacing="15">
                <Label Text="📍 Görev Konumu" FontSize="12" TextColor="#40916C" FontAttributes="Bold" />
                <Label Text="{Binding CreatedAt, StringFormat='📅 {0:dd MMMM yyyy}'}" FontSize="12" TextColor="Gray" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="25">

                <!-- FOTOĞRAFLAR (Alt Alta) -->
                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Önceki Hali" FontSize="12" TextColor="#707070" FontAttributes="Bold" Margin="5,0"/>
                        <Border StrokeShape="RoundRectangle 15" StrokeThickness="0">
                            <Image Source="{Binding FullInitialPhotoUrl}" Aspect="AspectFill" HeightRequest="250" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Sonraki Hali" FontSize="12" TextColor="#2D6A4F" FontAttributes="Bold" Margin="5,0"/>
                        <Border StrokeShape="RoundRectangle 15" StrokeThickness="2" Stroke="#2D6A4F">
                            <Image Source="{Binding FullAfterPhotoUrl}" Aspect="AspectFill" HeightRequest="250" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- BEĞENİ VE PUAN BİLGİSİ -->
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="5,0">
                    <!-- Beğeni Butonu / Sayısı (İleride Command eklenecek) -->
                    <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLikeTapped" />
                        </HorizontalStackLayout.GestureRecognizers>

                        <Image x:Name="ImgHeart" Source="like.png" HeightRequest="24" WidthRequest="24" />
                        <Label x:Name="LblLikeCount" Text="{Binding LikeCount, StringFormat='{0} Beğeni'}" FontSize="14" FontAttributes="Bold" TextColor="#1B4332" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Puan Bilgisi -->
                    <Border Grid.Column="2" BackgroundColor="#E8F5E9" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10,5">
                        <Label Text="{Binding TaskPoint, StringFormat='🏆 {0} Puan Kazandırdı'}" FontSize="12" FontAttributes="Bold" TextColor="#2D6A4F" />
                    </Border>
                </Grid>

                <!-- AÇIKLAMA METNİ -->
                <VerticalStackLayout Spacing="5" Margin="5,0">
                    <Label Text="Açıklama" FontSize="12" TextColor="#707070" FontAttributes="Bold" />
                    <Label Text="{Binding Content}" 
                           TextColor="#4A4A4A" 
                           FontSize="15" 
                           LineHeight="1.2" />
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10" />

                <!-- YORUMLAR BÖLÜMÜ (Şimdilik Aynı Bırakıldı) -->
                <Label Text="Yorumlar" FontSize="16" FontAttributes="Bold" TextColor="#1B4332" Margin="5,0" />
                <CollectionView x:Name="ColComments" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,10" ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCommentLikeTapped" />
                                </Grid.GestureRecognizers>

                                <Border Grid.Column="0" StrokeShape="RoundRectangle 25" HeightRequest="45" WidthRequest="45" VerticalOptions="Start">
                                    <!-- Fotoğraf yoksa varsayılan resim göster -->
                                    <Image Source="{Binding FullProfilePhotoUrl, TargetNullValue='user_avatar.png'}" Aspect="AspectFill" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <HorizontalStackLayout Spacing="8">
                                        <!-- Binding özelliklerini DTO'daki property adlarıyla eşleştirdik -->
                                        <Label Text="{Binding Username}" FontAttributes="Bold" TextColor="#1B4332" FontSize="14" />
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:HH:mm}'}" TextColor="#A0A0A0" FontSize="11" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding CommentText}" TextColor="#4A4A4A" FontSize="13" />

                                    <!-- Yorum Beğeni Kısmı (İleride Command eklenebilir) -->
                                    <HorizontalStackLayout Spacing="5" Margin="0,5,0,0">
                                        <Label Text="❤️" FontSize="12" />
                                        <Label Text="{Binding LikeCount}" FontSize="12" TextColor="Gray" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- YORUM YAZMA KISMI -->
        <Button Grid.Row="2" Text="YORUM YAZ" BackgroundColor="#1B4332" TextColor="White" FontAttributes="Bold" CornerRadius="0" HeightRequest="65" Clicked="OnOpenCommentPopupClicked" />

        <!-- POPUP -->
        <Grid x:Name="CommentPopup" Grid.RowSpan="3" BackgroundColor="#AA000000" IsVisible="False" Padding="20">
            <VerticalStackLayout VerticalOptions="Center" Spacing="15">
                <Border StrokeShape="RoundRectangle 20" BackgroundColor="White" Padding="20" StrokeThickness="0">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Fikrini Paylaş" FontAttributes="Bold" FontSize="18" TextColor="#1B4332" HorizontalOptions="Center" />
                        <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="#E0E0E0" BackgroundColor="#F9F9F9" Padding="10">
                            <Editor x:Name="EdiNewComment" Placeholder="Yorumunuzu buraya yazın..." HeightRequest="120" TextColor="Black" />
                        </Border>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <Button Text="İptal" BackgroundColor="Transparent" TextColor="#BC4749" Clicked="OnCloseCommentPopupClicked" />
                            <Button Grid.Column="1" Text="Gönder" BackgroundColor="#2D6A4F" TextColor="White" CornerRadius="10" Clicked="OnSendCommentClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>