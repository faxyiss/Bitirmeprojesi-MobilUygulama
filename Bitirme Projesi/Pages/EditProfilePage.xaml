<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bitirme_Projesi.Pages.EditProfilePage"
             BackgroundColor="#F8F9F2"
             Title="Profili Düzenle">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,10,0,20">
                <Grid HeightRequest="130" WidthRequest="130">
                    <Border StrokeShape="RoundRectangle 65" 
                            StrokeThickness="3" 
                            Stroke="#2D6A4F"
                            BackgroundColor="White"
                            Padding="2">
                        <Image x:Name="ProfileImage" 
                               Source="user_avatar.png" 
                               Aspect="AspectFill" />
                    </Border>

                    <Border BackgroundColor="#2D6A4F"
                            StrokeShape="RoundRectangle 20"
                            HeightRequest="40" WidthRequest="40"
                            VerticalOptions="End" HorizontalOptions="End"
                            Margin="5">
                        <Image Source="camera_icon.png" 
                               HeightRequest="24" 
                               WidthRequest="24" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center">
                        </Image>
                    </Border>

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangePhotoTapped" />
                    </Grid.GestureRecognizers>
                </Grid>
                <Label Text="Fotoğrafı Değiştir" 
                       TextColor="#2D6A4F" 
                       FontSize="14" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">

                <VerticalStackLayout Spacing="5">
                    <Label Text="Ad Soyad" TextColor="#1B4332" FontAttributes="Bold" Margin="5,0"/>
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#B7E4C7" BackgroundColor="White">
                        <Entry x:Name="FullNameEntry" 
                               Placeholder="Adınız Soyadınız" 
                               TextColor="#1B4332"
                               HeightRequest="50"
                               Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Hakkımda" TextColor="#1B4332" FontAttributes="Bold" Margin="5,0"/>
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#B7E4C7" BackgroundColor="White">
                        <Editor x:Name="BioEditor" 
                                Placeholder="Kendinden bahset..." 
                                TextColor="#1B4332"
                                HeightRequest="120"
                                AutoSize="Disabled"
                                Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <VerticalStackLayout Spacing="12" Margin="0,30,0,0">
                <Button Text="Değişiklikleri Kaydet" 
                        BackgroundColor="#2D6A4F" 
                        TextColor="White"
                        HeightRequest="55"
                        CornerRadius="15"
                        FontAttributes="Bold"
                        Clicked="OnSaveClicked" />

                <Button Text="Vazgeç" 
                        BackgroundColor="Transparent" 
                        TextColor="#707070"
                        HeightRequest="50"
                        Clicked="OnCancelClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>