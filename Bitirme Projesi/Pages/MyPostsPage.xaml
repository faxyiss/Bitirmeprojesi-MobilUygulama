<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bitirme_Projesi.Pages.MyPostsPage"
             Title="Başarımlarım"
             BackgroundColor="#F8F9F2">

    <Grid RowDefinitions="Auto, *">
        <VerticalStackLayout Grid.Row="0" BackgroundColor="White" Padding="20,15">
            <Label Text="PAYLAŞTIĞIM GÖREVLER" FontSize="18" FontAttributes="Bold" TextColor="#1B4332" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" x:Name="ColMyPosts" Margin="0,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="15,10" StrokeShape="RoundRectangle 15" BackgroundColor="White" StrokeThickness="0">
                        <VerticalStackLayout Spacing="10" Padding="15">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="#1B4332" />
                            <Label Text="{Binding CreatedAt, StringFormat='{0:dd MMM yyyy}'}" FontSize="12" TextColor="Gray" />

                            <!-- Fotoğraflar Yan Yana -->
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10" HeightRequest="150" Margin="0,10">
                                <Image Grid.Column="0" Source="{Binding FullInitialPhotoUrl}" Aspect="AspectFill" />
                                <Image Grid.Column="1" Source="{Binding FullAfterPhotoUrl}" Aspect="AspectFill" />
                            </Grid>

                            <Label Text="{Binding Content}" FontSize="14" TextColor="#4A4A4A" />

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,15,0,0">
                                <Button Grid.Column="0" 
                                    Text="Kaldır" 
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="Transparent" 
                                    TextColor="#BC4749" 
                                    BorderColor="#BC4749" 
                                    BorderWidth="1" 
                                    CornerRadius="10" 
                                    HeightRequest="40" 
                                    Clicked="OnRemovePostClicked"/>
                                <Button Grid.Column="1" 
                                    Text="Detay" 
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#2D6A4F" 
                                    TextColor="White" 
                                    CornerRadius="10" 
                                    HeightRequest="40" 
                                    Clicked="OnPostDetailClicked"/> 
                            </Grid>
                            
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="Henüz hiç başarı paylaşmadın." TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>