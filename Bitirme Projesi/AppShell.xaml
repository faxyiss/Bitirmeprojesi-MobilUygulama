<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Bitirme_Projesi.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Bitirme_Projesi.Pages"
    Title="Bitirme_Projesi">

   
        <!-- Giriş ve Kayıt (Sırayla) -->
        <ShellContent Title="Login" ContentTemplate="{DataTemplate local:LoginPage}" Route="Login" />

        <!-- Ana Sekmeler (Timeline, Quests, Profile vb.) -->
        <ShellContent Title="TimeLine" ContentTemplate="{DataTemplate local:TimeLinePage}" Route="TimeLine" />
        <ShellContent Title="Quests" ContentTemplate="{DataTemplate local:QuestsPage}" Route="Quests" />
        <ShellContent Title="Profile" ContentTemplate="{DataTemplate local:ProfilePage}" Route="Profile" /> 

</Shell>
